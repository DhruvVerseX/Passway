PORT=4000

# Shared secret for /admin/* routes (dashboard -> API). Replace with real
# session auth before this has more than one user.
PASSWAY_ADMIN_KEY=dev-admin-key-change-me

# Base64-encoded 32-byte (256-bit) master key for the local KMS stub.
# Generate one with: openssl rand -base64 32
# If unset, a random ephemeral key is generated at boot (dev only —
# secrets won't survive a restart).
PASSWAY_MASTER_KEY=
